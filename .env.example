# Client-side API Keys (Vite configuration fallback keys)
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=

# Server-side API Keys (Express backend keys)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
